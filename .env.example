# Copy to .env — Expo inlines EXPO_PUBLIC_* vars at bundle time.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# iBeacon UUID all DoctorIsHere pucks broadcast.
# Default matches the Locate Beacon app's default transmit UUID so a spare
# iPhone works as the demo beacon with zero configuration.
EXPO_PUBLIC_BEACON_UUID=2F234454-CF6D-4A0F-ADF2-F4911BA9FFA6

# Used only by scripts/seed.mjs (never shipped in the app):
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
